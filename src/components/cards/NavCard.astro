---
import EducationIcon from "@/components/icons/nav/EducationIcon.astro";
import HomeIcon from "@/components/icons/nav/HomeIcon.astro";
import ProjectIcon from "@/components/icons/nav/ProjectIcon.astro";
import SkillIcon from "@/components/icons/nav/SkillIcon.astro";

const pathname = Astro.url.pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";
const isActive = (path: string) => {
  const cleanPath = path.replace(/\/$/, "") || "/";
  return currentPath === cleanPath;
};
---

<nav>
  <ul>
    <li class={isActive("/") ? "active" : ""}>
      <a href="/" title="Inicio">
        <figure>
          <HomeIcon />
          <figcaption>Inicio</figcaption>
        </figure>
      </a>
    </li>
    <li class={isActive("/projects") ? "active" : ""}>
      <a href="/projects" title="Proyectos">
        <figure>
          <ProjectIcon />
          <figcaption>Proyectos</figcaption>
        </figure>
      </a>
    </li>
    <li class={isActive("/education") ? "active" : ""}>
      <a href="/education" title="Educación">
        <figure>
          <EducationIcon />
          <figcaption>Educación</figcaption>
        </figure>
      </a>
    </li>
    <li class={isActive("/skills") ? "active" : ""}>
      <a href="/skills" title="Skills">
        <figure>
          <SkillIcon />
          <figcaption>Skills</figcaption>
        </figure>
      </a>
    </li>
  </ul>
</nav>

<style>
  nav {
    background-color: var(--color-background-card);
    box-shadow: var(--shadow-card);
  }

  ul {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 1.3rem;
    padding: 0.5rem;
  }

  figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 70px;
  }

  li {
    position: relative;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  li::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 100%;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  li:hover::after,
  li.active::after {
    transform: scaleX(1);
  }

  li:hover,
  li.active {
    opacity: 1;
  }
</style>
