---
import { aboutme } from "@/data/profile/profile-data.json";
---

<article class="about-me-card">
  <header>
    <h1>Sobre mí</h1>
  </header>
  <section>
    <p>{aboutme}</p>
  </section>
</article>

<style>
  .about-me-card {
    width: 100%;
    height: auto;
    overflow: hidden;
    background-color: var(--color-background-card);
    box-shadow: var(--shadow-card);

    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 1rem;

    padding: 1rem;

    border-radius: 0.5rem;
  }

  h1 {
    font-weight: bold;
  }
</style>
