<div class="toast"></div>

<style>
  .toast {
    position: fixed;
    top: 2rem;
    left: 50%;
    background-color: var(--color-background-toast);
    color: var(--color-text-toast);
    border-radius: 2rem;
    padding: 1rem 1.5rem;
    text-align: center;
    z-index: 1000;

    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 20px);
    transition:
      transform 0.4s ease,
      opacity 0.4s ease;
  }

  .toast.show {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }
</style>
