---
import SocialCard from "@/components/cards/SocialCard.astro";
import TailwindIcon from "@/components/icons/posts/skills/TailwindIcon.astro";
import TypeScriptIcon from "@/components/icons/posts/skills/TypeScriptIcon.astro";
import { frontendB } from "@/data/posts/skills-data.json";

const { name, timeInit, description, category } = frontendB;
---

<SocialCard
  title={name}
  timeInit={timeInit}
  description={description}
  category={category}
>
  <div class="container-frontend">
    <figure class="typescript">
      <TypeScriptIcon />
      <figcaption>TypeScript</figcaption>
    </figure>
    <figure class="tailwind">
      <TailwindIcon />
      <figcaption>Tailwind</figcaption>
    </figure>
  </div>
</SocialCard>

<style>
  .container-frontend {
    width: 100%;
    height: 100%;

    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;

    gap: 1rem;
    padding: 1rem;
  }

  figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    background-color: #f5f5f5;
    gap: 3px;

    width: 100%;
    height: 100%;

    transition: transform 0.2s ease;
  }

  figure:hover {
    transform: scale(1.1);
  }

  figcaption {
    text-align: center;
    color: black;
  }

  .typescript:hover {
    background-color: #eaf2f8;
  }

  .tailwind:hover {
    background-color: #ebf5fb;
  }

  @media (max-width: 1250px) and (min-width: 900px) {
    figcaption {
      display: none;
    }
  }

  @media (max-width: 450px) {
    figcaption {
      display: none;
    }
  }
</style>
