---
import SocialCard from "@/components/cards/SocialCard.astro";
import { bufonio } from "@/data/posts/projects-data.json";

const { name, timeInit, timeEnd, description, category, image, url } = bufonio;
---

<SocialCard
  title={name}
  timeInit={timeInit}
  timeEnd={timeEnd}
  description={description}
  category={category}
>
  <div class="container-bufonio">
    <a href={url} target="_blank">
      <img src={image} alt={name} />
    </a>
  </div>
</SocialCard>

<style>
  .container-bufonio {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem;
    background: linear-gradient(135deg, #ffffff 0%, #000000 100%);
  }

  .container-bufonio img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 1rem;
    transition: transform 0.2s ease;
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.3));
  }

  .container-bufonio img:hover{
    transform: scale(1.1);
    filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.4));
  }
</style>
